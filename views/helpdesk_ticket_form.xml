<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="helpdesk_ticket_form_inherit" model="ir.ui.view">
            <field name="name">helpdesk.ticket.form.inherit</field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='email_cc']" position="after">
                    <field name="deadline"/>
                </xpath>
                <xpath expr="//field[@name='team_id']" position="before">
                    <field name="category_id"/>
                    <field name="subcategory_id" domain="[('category_id', '=', category_id)]"/>
                    <field name="item_id" domain="[('subcategory_id', '=', subcategory_id)]"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
