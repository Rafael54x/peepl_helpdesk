<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="helpdesk_ticket_form_inherit" model="ir.ui.view">
            <field name="name">helpdesk.ticket.form.inherit</field>
            <field name="model">helpdesk.ticket</field>
            <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_save_as_draft" string="Save as Draft" type="object"
                        class="btn-secondary" invisible="is_draft or id"/>
                    <button name="action_submit" string="Save &amp; Send" type="object"
                        class="btn-primary" invisible="not is_draft"/>
                    <field name="is_draft" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='priority']" position="attributes">
                    <attribute name="readonly">has_auto_priority</attribute>
                </xpath>
                <xpath expr="//field[@name='email_cc']" position="after">
                    <field name="deadline"/>
                    <field name="has_auto_priority" invisible="1"/>
                    <field name="opened_by_id" string="Opened By" readonly="1"/>
                </xpath>
                <xpath expr="//field[@name='team_id']" position="before">
                    <field name="category_id" required="1"/>
                    <field name="subcategory_id"
                        domain="[('category_id', '=', category_id)]"
                        readonly="not category_id"
                        required="1"/>
                    <field name="item_category_id"
                        domain="[('subcategory_id', '=', subcategory_id)]"
                        readonly="not subcategory_id"
                        required="1"/>
                    <field name="item_id"
                        domain="[('item_category_id', '=', item_category_id)]"
                        readonly="not item_category_id"
                        required="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
