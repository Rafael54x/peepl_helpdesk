<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="helpdesk_sla_form_inherit" model="ir.ui.view">
            <field name="name">helpdesk.sla.form.inherit</field>
            <field name="model">helpdesk.sla</field>
            <field name="inherit_id" ref="helpdesk.helpdesk_sla_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='team_id']" position="after">
                    <field name="auto_priority" widget="boolean_toggle" string="Enable Auto Priority"/>
                </xpath>
                <xpath expr="//field[@name='priority']" position="attributes">
                    <attribute name="invisible">auto_priority</attribute>
                </xpath>
                <xpath expr="//field[@name='exclude_stage_ids']" position="after">
                    <separator colspan="2" string="Auto Priority Thresholds" invisible="not auto_priority"/>
                    <label for="priority_threshold_low" string="Low Threshold" invisible="not auto_priority"/>
                    <div class="o_row" invisible="not auto_priority">
                        <field name="priority_threshold_low" class="oe_inline" widget="float_time"/>
                        <span>hours</span>
                    </div>
                    <label for="priority_threshold_medium" string="Medium Threshold" invisible="not auto_priority"/>
                    <div class="o_row" invisible="not auto_priority">
                        <field name="priority_threshold_medium" class="oe_inline" widget="float_time"/>
                        <span>hours</span>
                    </div>
                    <label for="priority_threshold_high" string="High Threshold" invisible="not auto_priority"/>
                    <div class="o_row" invisible="not auto_priority">
                        <field name="priority_threshold_high" class="oe_inline" widget="float_time"/>
                        <span>hours</span>
                    </div>
                    <label for="priority_threshold_urgent" string="Urgent Threshold" invisible="not auto_priority"/>
                    <div class="o_row" invisible="not auto_priority">
                        <field name="priority_threshold_urgent" class="oe_inline" widget="float_time"/>
                        <span>hours</span>
                    </div>
                    <div class="alert alert-info" colspan="2" invisible="not auto_priority" role="alert">
                        <p><strong>Priority is automatically set based on time remaining until ticket deadline:</strong></p>
                        <ul class="mb-0 mt-2">
                            <li><strong>Low:</strong> Time remaining &gt; Low Threshold ☆☆☆</li>
                            <li><strong>Medium:</strong> Medium Threshold ≤ Time ≤ Low Threshold ★☆☆</li>
                            <li><strong>High:</strong> High Threshold ≤ Time ≤ Medium Threshold ★★☆</li>
                            <li><strong>Urgent:</strong> Time remaining ≤ Urgent Threshold ★★★</li>
                        </ul>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
