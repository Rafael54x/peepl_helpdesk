<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="helpdesk_ticket_action_draft" model="ir.actions.act_window">
            <field name="name">Draft Tickets</field>
            <field name="res_model">helpdesk.ticket</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('is_draft', '=', True)]</field>
            <field name="context">{'default_is_draft': True, 'search_default_is_draft': True}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No draft tickets found.
                </p>
            </field>
        </record>

        <menuitem
            id="helpdesk_ticket_menu_draft"
            name="Draft Tickets"
            parent="helpdesk.helpdesk_ticket_menu_main"
            action="helpdesk_ticket_action_draft"
            sequence="15"/>
    </data>
</odoo>
